{
  "name": "novapulse",
  "version": "1.0.0",
  "description": "NovaPulse - Stock Trading Platform",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "dashboard"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:dashboard\"",
    "dev:backend": "npm --prefix backend start",
    "dev:frontend": "cross-env PORT=3001 NODE_PATH=. npm --prefix frontend start",
    "dev:dashboard": "cross-env PORT=3000 NODE_PATH=. npm --prefix dashboard start",
    "build": "npm --prefix backend run build && npm --prefix frontend run build && npm --prefix dashboard run build",
    "build:backend": "npm --prefix backend run build",
    "build:frontend": "cross-env NODE_PATH=. npm --prefix frontend run build",
    "build:dashboard": "cross-env NODE_PATH=. npm --prefix dashboard run build",
    "test": "npm --prefix backend run test && npm --prefix frontend run test && npm --prefix dashboard run test",
    "test:backend": "npm --prefix backend run test",
    "test:frontend": "npm --prefix frontend run test",
    "test:dashboard": "npm --prefix dashboard run test"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^5.18.0",
    "@mui/material": "^5.18.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.17.0",
    "bcryptjs": "^3.0.3",
    "body-parser": "^2.2.0",
    "chart.js": "^4.5.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.20.0",
    "otplib": "^13.4.1",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "passport-local-mongoose": "^8.0.0",
    "razorpay": "^2.9.6",
    "react": "^19.1.1",
    "react-chartjs-2": "^5.3.1",
    "react-cookie": "^8.1.2",
    "react-dom": "^19.1.1",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.9.5",
    "react-scripts": "5.0.1",
    "react-toastify": "^11.1.0",
    "smartapi-javascript": "^1.0.27",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "web-vitals": "^2.1.4",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "ajv": "^8.20.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.0"
  }
}
